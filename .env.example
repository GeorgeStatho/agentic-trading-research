# Alpaca
PUBLIC_KEY=your_alpaca_public_key
PRIVATE_KEY=your_alpaca_private_key
ALPACA_PAPER=true

# Google Cloud / Vertex AI
LLM_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=global
VERTEX_DEFAULT_MODEL=gemini-2.5-flash
# Optional Vertex retry tuning
# VERTEX_MAX_ATTEMPTS=5
# VERTEX_RETRY_INITIAL_DELAY_SECONDS=2
# VERTEX_RETRY_MAX_DELAY_SECONDS=30
# MACRO_NEWS_BATCH_PAUSE_SECONDS=0.75

# Local Docker uses the host gcloud ADC directory automatically.
# Run `gcloud auth application-default login` on the host once, then rebuild.
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json

# Recommended stage split
# High-volume classification/extraction stages use Flash-Lite to keep costs down.
WORLD_NEWS_MODEL=gemini-2.5-flash-lite
MACRO_NEWS_MODEL=gemini-2.5-flash-lite
SECTOR_OPPURUNTIST_MODEL=gemini-2.5-flash-lite
INDUSTRY_OPPURUNTINST_MODEL=gemini-2.5-flash-lite
COMPANY_OPPURUNTIST_MODEL=gemini-2.5-flash-lite

# Mid-tier reasoning stage.
STRATEGIST_MODEL=gemini-2.5-flash

# Final decision stage.
MANAGER_MODEL=gemini-2.5-pro

# Portfolio history API defaults
PORTFOLIO_HISTORY_PERIOD=1M
PORTFOLIO_HISTORY_TIMEFRAME=1D
PORTFOLIO_HISTORY_INTRADAY_REPORTING=market_hours
PORTFOLIO_HISTORY_PNL_RESET=per_day

# Worker / execution settings
AGENT_OPTION_ORDER_QTY=1
MANAGER_OPTION_CHAIN_LIMIT_PER_TYPE=6
# Optional: fetch a wider raw chain from Alpaca, then trim to nearest/OTM contracts.
# MANAGER_OPTION_CHAIN_FETCH_MULTIPLIER=6

# Database storage
# Local Python defaults to Data/stock_experiment.db.
# Docker sets DB_PATH automatically to a persistent named volume.
# DB_PATH=/var/lib/stock-experiment/stock_experiment.db
# COLD_START_SANITY_CHECK=true

# Shared runtime file locations
SCRIPT_STATUS_PATH=/shared/script_status.json
TRADE_EXECUTION_OUTPUT_PATH=/shared/trade_execution_output.json

# Optional local Ollama fallback
# Uncomment these if you want to run with LLM_PROVIDER=ollama instead.
# OLLAMA_HOST=http://ollama:11434
# WORLD_NEWS_OLLAMA_HOST=http://ollama:11434
# MACRO_NEWS_OLLAMA_HOST=http://ollama:11434
# SECTOR_OPPURUNTIST_OLLAMA_HOST=http://ollama:11434
# INDUSTRY_OPPURUNTINST_OLLAMA_HOST=http://ollama:11434
# COMPANY_OPPURUNTIST_OLLAMA_HOST=http://ollama:11434
# STRATEGIST_OLLAMA_HOST=http://ollama:11434
# MANAGER_OLLAMA_HOST=http://ollama:11434

# Optional scraping tuning
# WEBSCRAPING_ARTICLE_BACKEND=scrapy
# WEBSCRAPING_PLAYWRIGHT_CONCURRENCY=2
# WEBSCRAPING_RENDERED_EXTRACTION_WORKERS=2
